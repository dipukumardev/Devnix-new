        "type": 302
      },
      {
        "source": "/work/fintech-landing-page",
        "destination": "/#work",
        "type": 302
      },
      {
        "source": "/work/brand-identity-overhaul",
        "destination": "/#work",
        "type": 302
      },
      {
        "source": "/work/healthcare-app",
        "destination": "/#work",
        "type": 302
